FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     simpleFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         10000;

deltaT          1;

writeControl    timeStep;
writeInterval   100;

purgeWrite      0;

writeFormat     ascii;
writePrecision  6;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

functions
{
    rotorForces
    {
        type            forces;
        libs            ("libforces.so");

        patches         (rotor);
	rho		rhoInf;
        rhoInf          1.225;
        CofR            (0 0 0);

        writeControl    timeStep;
        writeInterval   10;

	log		false;
    }

    rotorForceCoeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");

        patches         (rotor);

        rho             rhoInf;
        rhoInf          1.225;

        CofR            (0 0 0);

        liftDir         (0 1 0);
        dragDir         (1 0 0);
        pitchAxis       (1 0 0);

        magUInf         10;
        lRef            100;
        Aref            7853.9816;

        writeControl    timeStep;
        writeInterval   10;

	log		false;
    }
}


