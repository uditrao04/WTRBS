FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale 1;		// Units: mm

//Domain is kept intentionally small to reduce computational time
vertices
(
	(-200 -200 -200)   // 0
	(300  -200 -200)   // 1
	(300   200 -200)   // 2
	(-200  200 -200)   // 3
	(-200 -200  200)   // 4
	(300  -200  200)   // 5
	(300   200  200)   // 6
	(-200  200  200)   // 7
);

blocks
(
	// Intentionally coarse mesh till Mesh Convergence Studies
	hex (0 1 2 3 4 5 6 7) (60 40 40) simpleGrading (1 1 1)
);

edges
(
);

boundary
(
	inlet
	{
		type patch;
        	faces
        	(
            		(0 3 7 4)
        	);
    	}

    	outlet
    	{
        	type patch;
        	faces
        	(
            		(1 5 6 2)
        	);
    	}

    	sideWalls
    	{
        	type patch;
        	faces
        	(
            		(0 1 2 3)
            		(4 7 6 5)
            		(0 4 5 1)
            		(3 2 6 7)
        	);
    	}
);

mergePatchPairs
(
);

