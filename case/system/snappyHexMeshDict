FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       false;


// -------------------------------
// GEOMETRY
// -------------------------------

geometry
{
    rotorRemesh.stl
    {
        type triSurfaceMesh;
        name rotor;
    }

    rotatingZone
    {
        type searchableCylinder;
        point1 (-10 0 0);
        point2 (60 0 0);
        radius 60;
    }
}


// -------------------------------
// CASTELLATED MESH
// -------------------------------

castellatedMeshControls
{
    maxLocalCells 200000;
    maxGlobalCells 500000;
    minRefinementCells 10;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 3;

    features
    (
    );

    refinementSurfaces
    {
        rotor
        {
            level (2 3);
            patchInfo
            {
                type wall;
            }
        }
    }

    resolveFeatureAngle 60;

    refinementRegions
    {
        rotatingZone
        {
            mode inside;
            levels ((1e15 3));

            cellZone rotatingZone;
            faceZone rotatingZone;
            cellZoneInside inside;
        }
    }

    locationInMesh (100 0 0);

    allowFreeStandingZoneFaces true;
}


// -------------------------------
// SNAP
// -------------------------------

snapControls
{
    nSmoothPatch 5;
    tolerance 3.0;
    nSolveIter 50;
    nRelaxIter 5;

    nFeatureSnapIter 10;
    implicitFeatureSnap false;
    explicitFeatureSnap false;
    multiRegionFeatureSnap false;
}


// -------------------------------
// ADD LAYERS
// -------------------------------

addLayersControls
{
    relativeSizes true;

    layers
    {
    }

    expansionRatio 1.0;
    finalLayerThickness 0.3;
    minThickness 0.1;
    nGrow 0;

    featureAngle 60;
    slipFeatureAngle 30;
    nRelaxIter 3;
    nSmoothSurfaceNormals 1;
    nSmoothNormals 3;
    nSmoothThickness 10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedialAxisAngle 90;
    nBufferCellsNoExtrude 0;
    nLayerIter 0;
}


// -------------------------------
// MESH QUALITY
// -------------------------------

meshQualityControls
{
    maxNonOrtho          65;
    maxBoundarySkewness  20;
    maxInternalSkewness  4;
    maxConcave           80;
    minFlatness          0.5;
    minVol               1e-13;
    minTetQuality        1e-15;
    minArea              -1;
    minTwist             0.02;
    minDeterminant       0.001;
    minFaceWeight        0.02;
    minVolRatio          0.01;
    minTriangleTwist     -1;
    minEdgeLength        -1;
    nSmoothScale         4;
    errorReduction       0.75;
}


// -------------------------------
// WRITE FLAGS
// -------------------------------

writeFlags
(
    scalarLevels
    layerSets
    layerFields
);


// -------------------------------
// MERGE TOLERANCE
// -------------------------------

mergeTolerance 1e-6;

// ************************************************************************* //
